{
  "name": "curahealthcare-automation-framework",
  "version": "1.0.0",
  "description": "Playwright POM framework with fixtures, allure reporting, and CI/CD integration",
  "scripts": {
    "test": "npx playwright test",
    "test:ci": "npx playwright test --config=playwright.ci.config.ts",
    "test:headed": "npx playwright test --headed",
    "test:report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-playwright": "^3.7.1",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
